# ─── CyberLabs Backend — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env — it is already in .gitignore.

# ── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (Platform) ────────────────────────────────────────────────────────
# Main platform database (users, labs, enrollments, scores).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cyberlabs

# ── JWT ──────────────────────────────────────────────────────────────────────
# At least 32 characters. Use: openssl rand -hex 32
JWT_SECRET=changeme-use-openssl-rand-hex-32
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=changeme-another-long-random-string
JWT_REFRESH_EXPIRY=7d

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── VM Service (cyberlabs-vm-service) ───────────────────────────────────────
# Internal URL of the vm-service (never exposed to frontend).
# Local dev: http://localhost:3001
# Production: http://vm-service.internal:3001
VM_SERVICE_URL=http://localhost:3001

# Shared secret — MUST match VM_SERVICE_API_KEY in cyberlabs-vm-service
VM_SERVICE_API_KEY=changeme-use-a-long-random-string

# ── Frontend URLs (for CORS + redirect links) ─────────────────────────────────
# Main platform frontend
FRONTEND_URL=https://test.cyber-labs.tech
# Labs sub-application
LABS_FRONTEND_URL=https://labs.cyber-labs.tech

# ── OAuth (optional) ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=no-reply@cyber-labs.tech

# ── Stripe (optional) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
