// ============================================================================
// LABS
// ============================================================================

model Lab {
  id         String     @id @default(uuid())
  courseLabs CourseLab[]
  courseId   String?

  title          String
  ar_title       String?
  description    String?
  ar_description String?
  difficulty     Difficulty       @default(BEGINNER)

  category      CATEGORY         @default(WEB_SECURITY)
  executionMode LabExecutionMode @default(SHARED_BACKEND)
  scenario      String?          @db.Text
  ar_scenario   String?          @db.Text
  engineConfig  Json?
  skills        String[]

  goal          String?          @db.Text
  ar_goal       String?
  briefing      Json?
  stepsOverview Json?
  solution      Json?
  postSolve     Json?

  slug          String  @unique
  imageUrl      String?
  duration      Int?
  labUrl        String?
  flagAnswer    String?
  maxAttempts   Int?
  timeLimit     Int?
  xpReward      Int     @default(0)
  pointsReward  Int     @default(0)
  pointsPerHint Int     @default(10)
  pointsPerFail Int     @default(5)
  initialState  Json    @default("{}")
  isolationMode String  @default("database")

  steps Json?

  // ─── NEW: Environment & Concept metadata ────────────────────────────────
  environmentType  LabEnvironmentType @default(DEFAULT)
  canonicalConceptId String?
  variantOfLabId     String?
  targetRole         String?
  hintPenaltyMode    HintPenaltyMode @default(PERCENTAGE)
  flagPolicyType     FlagPolicyType  @default(PER_USER_PER_LAB)
  immersiveAssets    Json?
  missionBrief       Json?
  labInfo            Json?
  scenarioAdmin      Json?
  // ─────────────────────────────────────────────────────────────────────────

  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pathModules     PathModule[]
  usersProgress   UserLabProgress[]
  hints           LabHint[]
  discussions     Discussion[]
  reviews         LabReview[]
  submissions     LabSubmission[]
  instances       LabInstance[]
  launchTokens    LabLaunchToken[]
  genericUsers    LabGenericUser[]
  genericBanks    LabGenericBank[]
  genericContents LabGenericContent[]
  genericLogs     LabGenericLog[]

  // audit relations
  hintUsages      LabHintUsage[]
  flagRecords     LabFlagRecord[]

  // ─── VM Labs additive relation (Step 1.3) ─────────────────────────────
  vmLabTemplates  VmLabTemplate[]

  @@index([courseId])
  @@index([difficulty])
  @@index([isPublished])
  @@index([canonicalConceptId])
  @@index([environmentType])
  @@map("labs")
}


model CourseLab {
  courseId String
  labId    String
  order    Int    @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lab    Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@id([courseId, labId])
  @@index([courseId])
  @@index([labId])
  @@map("course_labs")
}

model LabInstance {
    id     String @id @default(cuid())
  userId String
  labId  String

  state Json @default("{}")

  balance Int @default(5000)

  isActive  Boolean   @default(true)
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  
  launchTokens LabLaunchToken[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab  Lab  @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([userId, labId])
  @@index([userId])
  @@index([labId])
  @@map("LabInstance")
}

model LabLaunchToken {
    id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  labId      String
  instanceId String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab      Lab         @relation(fields: [labId], references: [id], onDelete: Cascade)
  instance LabInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@map("lab_launch_tokens")
}

model LabHint {
    id         String  @id @default(uuid())
  labId      String
  lab        Lab     @relation(fields: [labId], references: [id], onDelete: Cascade)
  content    String  @db.Text
  ar_content String? @db.Text
  order      Int
  xpCost     Int     @default(0)

  // NEW: percentage penalty at submission time (0–100)
  penaltyPercent Int @default(0)

  hintUsages LabHintUsage[]

  @@unique([labId, order])
  @@index([labId])
  @@map("lab_hints")
}

model UserLabProgress {
    id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  lab    Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)
  labId  String

  progress      Int       @default(0)
  attempts      Int       @default(0)
  hintsUsed     Int       @default(0)
  flagSubmitted Boolean   @default(false)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  lastAccess    DateTime?

  status        String?   @default("in_progress")

  @@unique([userId, labId])
  @@index([userId])
  @@index([labId])
  @@index([completedAt])
  @@map("user_lab_progress")
}

// ─── Lab Hint Audit Log ───────────────────────────────────────────────
model LabHintUsage {
  id         String   @id @default(cuid())
  userId     String
  labId      String
  hintId     String
  hintOrder  Int
  xpCost     Int
  usedAt     DateTime @default(now())

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab   Lab     @relation(fields: [labId], references: [id], onDelete: Cascade)
  hint  LabHint @relation(fields: [hintId], references: [id], onDelete: Cascade)

  @@unique([userId, labId, hintOrder])
  @@index([userId, labId])
  @@index([labId])
  @@map("lab_hint_usages")
}

// ─── Lab Flag Record ──────────────────────────────────────────────────
model LabFlagRecord {
  id          String    @id @default(cuid())
  userId      String
  labId       String
  attemptId   String
  flagHash    String
  used        Boolean   @default(false)
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab   Lab  @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([userId, labId, attemptId])
  @@index([flagHash])
  @@index([userId, labId])
  @@map("lab_flag_records")
}

